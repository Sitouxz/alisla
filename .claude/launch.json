{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static HTTP Server (Python)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "3000"],
      "port": 3000
    },
    {
      "name": "Static HTTP Server (Node npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "."],
      "port": 3000,
      "autoPort": true
    }
  ]
}
